<svg xmlns="http://www.w3.org/2000/svg" width="800" height="450" viewBox="0 0 800 450">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a2a3a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f1923;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f5a623;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#d4891a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="accent2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4A90D9;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2ECC71;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- 背景 -->
  <rect width="800" height="450" fill="url(#bg)" />

  <!-- 网格 -->
  <g stroke="#ffffff08" stroke-width="0.5">
    <line x1="0" y1="0" x2="0" y2="450"/><line x1="50" y1="0" x2="50" y2="450"/>
    <line x1="100" y1="0" x2="100" y2="450"/><line x1="150" y1="0" x2="150" y2="450"/>
    <line x1="200" y1="0" x2="200" y2="450"/><line x1="250" y1="0" x2="250" y2="450"/>
    <line x1="300" y1="0" x2="300" y2="450"/><line x1="350" y1="0" x2="350" y2="450"/>
    <line x1="400" y1="0" x2="400" y2="450"/><line x1="450" y1="0" x2="450" y2="450"/>
    <line x1="500" y1="0" x2="500" y2="450"/><line x1="550" y1="0" x2="550" y2="450"/>
    <line x1="600" y1="0" x2="600" y2="450"/><line x1="650" y1="0" x2="650" y2="450"/>
    <line x1="700" y1="0" x2="700" y2="450"/><line x1="750" y1="0" x2="750" y2="450"/>
    <line x1="0" y1="0" x2="800" y2="0"/><line x1="0" y1="50" x2="800" y2="50"/>
    <line x1="0" y1="100" x2="800" y2="100"/><line x1="0" y1="150" x2="800" y2="150"/>
    <line x1="0" y1="200" x2="800" y2="200"/><line x1="0" y1="250" x2="800" y2="250"/>
    <line x1="0" y1="300" x2="800" y2="300"/><line x1="0" y1="350" x2="800" y2="350"/>
    <line x1="0" y1="400" x2="800" y2="400"/>
  </g>

  <!-- 装饰光点 -->
  <circle cx="120" cy="80" r="3" fill="#f5a623" opacity="0.4">
    <animate attributeName="opacity" values="0.4;0.8;0.4" dur="3s" repeatCount="indefinite" />
  </circle>
  <circle cx="680" cy="120" r="2" fill="#4A90D9" opacity="0.5">
    <animate attributeName="opacity" values="0.5;0.9;0.5" dur="2.5s" repeatCount="indefinite" />
  </circle>
  <circle cx="400" cy="380" r="2.5" fill="#2ECC71" opacity="0.3">
    <animate attributeName="opacity" values="0.3;0.7;0.3" dur="4s" repeatCount="indefinite" />
  </circle>

  <!-- 左侧：爬虫图标（蜘蛛网风格） -->
  <g transform="translate(100, 140)" stroke="#f5a623" stroke-width="1.5" fill="none" opacity="0.6">
    <!-- 蜘蛛网 -->
    <circle cx="0" cy="0" r="60"/>
    <circle cx="0" cy="0" r="40"/>
    <circle cx="0" cy="0" r="20"/>
    <line x1="0" y1="-60" x2="0" y2="60"/>
    <line x1="-60" y1="0" x2="60" y2="0"/>
    <line x1="-42" y1="-42" x2="42" y2="42"/>
    <line x1="-42" y1="42" x2="42" y2="-42"/>
  </g>

  <!-- 中间：数据流 -->
  <g transform="translate(320, 170)">
    <!-- LLM 大脑 -->
    <circle cx="0" cy="0" r="50" fill="none" stroke="url(#accent2)" stroke-width="2" opacity="0.8"/>
    <circle cx="0" cy="0" r="30" fill="url(#accent2)" opacity="0.15"/>
    <text x="0" y="5" text-anchor="middle" fill="#4A90D9" font-size="16" font-family="monospace" font-weight="bold">LLM</text>

    <!-- 连接线 -->
    <line x1="-90" y1="0" x2="-50" y2="0" stroke="#f5a623" stroke-width="2" stroke-dasharray="4,3" opacity="0.6">
      <animate attributeName="stroke-dashoffset" from="14" to="0" dur="0.8s" repeatCount="indefinite" />
    </line>
    <line x1="50" y1="0" x2="90" y2="0" stroke="#2ECC71" stroke-width="2" stroke-dasharray="4,3" opacity="0.6">
      <animate attributeName="stroke-dashoffset" from="14" to="0" dur="0.8s" repeatCount="indefinite" />
    </line>
  </g>

  <!-- 右侧：数据库/文档 -->
  <g transform="translate(580, 160)" fill="none" stroke="#2ECC71" stroke-width="1.5" opacity="0.7">
    <!-- 数据库图标 -->
    <ellipse cx="0" cy="-25" rx="35" ry="10"/>
    <line x1="-35" y1="-25" x2="-35" y2="20"/>
    <line x1="35" y1="-25" x2="35" y2="20"/>
    <ellipse cx="0" cy="20" rx="35" ry="10"/>
    <line x1="-35" y1="-5" x2="-35" y2="20"/>
    <line x1="35" y1="-5" x2="35" y2="20"/>
    <!-- 文档 -->
    <rect x="-15" y="-12" width="30" height="38" rx="3" stroke-width="1"/>
    <line x1="-8" y1="-4" x2="8" y2="-4" stroke-width="0.8"/>
    <line x1="-8" y1="2" x2="8" y2="2" stroke-width="0.8"/>
    <line x1="-8" y1="8" x2="4" y2="8" stroke-width="0.8"/>
  </g>

  <!-- 标题 -->
  <text x="400" y="310" text-anchor="middle" fill="#f5a623" font-size="28" font-family="sans-serif" font-weight="bold">自动化爬虫 Agent</text>
  <text x="400" y="340" text-anchor="middle" fill="#8899aa" font-size="14" font-family="sans-serif">JD 市场分析 · 技术文档知识库</text>

  <!-- 底部松树剪影 -->
  <g transform="translate(0, 400)" fill="#0d1520" opacity="0.7">
    <polygon points="30,50 50,0 70,50"/>
    <polygon points="60,50 80,10 100,50"/>
    <polygon points="90,50 110,5 130,50"/>
    <polygon points="650,50 670,0 690,50"/>
    <polygon points="680,50 700,10 720,50"/>
    <polygon points="710,50 730,0 750,50"/>
  </g>
</svg>
